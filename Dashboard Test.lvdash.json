{
  "datasets": [
    {
      "name": "e7eeaeea",
      "displayName": "contagem_de_cpfs",
      "queryLines": [
        "SELECT \r\n",
        "COUNT(DISTINCT cpf)\r\n",
        "FROM costumers_registrations.gold.registrations;"
      ]
    },
    {
      "name": "3f185229",
      "displayName": "contagem_de_cps_por_estado",
      "queryLines": [
        "SELECT \r\n",
        "    estado,\r\n",
        "    COUNT(DISTINCT cpf) AS qtd_cpfs_distintos\r\n",
        "FROM costumers_registrations.gold.registrations\r\n",
        "GROUP BY estado;"
      ]
    },
    {
      "name": "c928947f",
      "displayName": "contagem_cpfs_M_F",
      "queryLines": [
        "SELECT\r\n",
        "COUNT(DISTINCT CASE WHEN genero = 'M' THEN cpf END) AS qtd_masculino,\r\n",
        "COUNT(DISTINCT CASE WHEN genero = 'F' THEN cpf END) AS qtd_feminino\r\n",
        "FROM costumers_registrations.gold.registrations\r\n",
        "WHERE cpf IS NOT NULL;"
      ]
    },
    {
      "name": "c785e368",
      "displayName": "cadastros_por_mes",
      "queryLines": [
        "SELECT\r\n",
        "DATE_FORMAT(data_cadastro, 'yyyy-MM') AS mes_ano,\r\n",
        "COUNT(DISTINCT cpf) AS qtd_cpf_distinct\r\n",
        "FROM costumers_registrations.gold.registrations\r\n",
        "GROUP BY mes_ano;"
      ],
      "catalog": "costumers_registrations",
      "schema": "gold"
    },
    {
      "name": "f0e94533",
      "displayName": "data_cadastro",
      "queryLines": [
        "SELECT data_cadastro\r\n",
        "FROM costumers_registrations.gold.registrations"
      ],
      "catalog": "costumers_registrations",
      "schema": "gold"
    }
  ],
